@model object
@{
    var carrito = (List<CarritoASP.Models.Producto>)ViewBag.Carrito;
    var catalogo = (List<string>)ViewBag.Catalogo;
    ViewData["Title"] = "Carrito ASP.NET";
}
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Carrito ASP.NET Core</title>
<style>
body{font-family:Arial,sans-serif;max-width:800px;margin:2rem auto}
table{width:100%;border-collapse:collapse;margin-top:1rem}
th,td{padding:8px 12px;border:1px solid #ddd;text-align:left}
th{background:#512da8;color:white}
.btn{padding:6px 14px;border:none;border-radius:4px;cursor:pointer}
.btn-add{background:#27ae60;color:white}
.btn-del{background:#e74c3c;color:white}
.btn-clear{background:#7f8c8d;color:white}
.btn-destroy{background:#8e44ad;color:white}
</style>
</head>
<body>
<h1>Tienda - Sesión ASP.NET Core</h1>

<h2>Catálogo</h2>
<form asp-action="Agregar" method="post">
  <select name="nombre">
    @foreach (var item in catalogo)
    {
      <option value="@item">@item</option>
    }
  </select>
  <button class="btn btn-add">Agregar al carrito</button>
</form>

<h2>Carrito</h2>
@if (!carrito.Any())
{
  <p>El carrito está vacío.</p>
  <form asp-action="DestruirSesion" method="post" style="margin-top:1rem;">
    <button class="btn btn-destroy" title="Destruye la sesión actual y genera una nueva cookie .AspNetCore.Session">
      🔄 Destruir y Nueva Sesión (Cambiar Cookie)
    </button>
  </form>
}
else
{
  <table>
    <tr><th>Producto</th><th>Precio</th><th>Acción</th></tr>
    @for (int i = 0; i < carrito.Count; i++)
    {
      <tr>
        <td>@carrito[i].Nombre</td>
        <td>$@carrito[i].Precio</td>
        <td>
          <form asp-action="Eliminar" method="post" style="margin:0">
            <input type="hidden" name="indice" value="@i">
            <button class="btn btn-del">Eliminar</button>
          </form>
        </td>
      </tr>
    }
  </table>
  <p><strong>Total: $@carrito.Sum(p => p.Precio)</strong></p>
  <div style="display:flex;gap:10px;flex-wrap:wrap;">
    <form asp-action="Limpiar" method="post" style="margin:0">
      <button class="btn btn-clear" title="Borra los ítems pero mantienes el mismo Session ID">
        🧹 Vaciar carrito (Mantener sesión)
      </button>
    </form>
    <form asp-action="DestruirSesion" method="post" style="margin:0">
      <button class="btn btn-destroy" title="Destruye la sesión actual y genera una nueva cookie .AspNetCore.Session">
        🔄 Destruir y Nueva Sesión (Cambiar Cookie)
      </button>
    </form>
  </div>
}

<p style="color:#999;font-size:0.8rem">
  Session ID: @ViewBag.SessionId
</p>
</body>
</html>
